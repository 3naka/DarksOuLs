{
    "name": "AutoClean",
    "version": "0.1.4",
    "styleFileList": [
    ],
    "scriptFileList_earlyload": [
    ],
    "scriptFileList_inject_early": [
    ],
    "scriptFileList_preload": [
    ],
    "scriptFileList": [
      "AutoClean_js.js"
    ],
    "tweeFileList": [
    ],
    "imgFileList": [
 ],
    "additionFile": [
     
      "readme.md"
     
    ],
    "addonPlugin": [
      {
        "modName": "TweeReplacer",
        "addonName": "TweeReplacerAddon",
        "modVersion": "1.0.0",
        "params": [

          {
            "passage": "Widgets Temple",
            "findString": "<<set $temple_quarters -= 10>>",
            "replace": "<<if $housekeeping lt 1000 and $temple_rank isnot \"initiate\">><<set $temple_quarters -= 10>><</if>>"
          },
          {
            "passage": "Widgets Temple",
            "findString": "<<set $temple_garden -= 10>>",
            "replace": "<<if $tending lt 1000 and $temple_rank isnot \"initiate\">><<set $temple_garden -= 10>><</if>>"
          },
		    {
            "passage": "Widgets Cabin",
            "findRegex": "<<elseif \\$edengarden is 4>>\\s+.+\\s+<br><br>",
            "replace": "<<elseif $edengarden is 4>>\n<span class=\"green\">伊甸的庄稼没有杂草。</span>\n<br>\n<<gardenicon \"weeds\">><<link [[照料庄稼 (3:00)|Clearing Weeding]]>><<tending 1>><<tiredness 12>><<npcincr Eden love 1>><</link>><<gtiredness>><<glove>><<gtending>>\n<br><br>"       
          },
		  {
            "passage": "Clearing Weeding",
            "findString": "<<set $outside to 1>><<set $location to \"cabin\">><<effects>>",
            "replace": "<<set $outside to 1>><<set $location to \"cabin\">><<effects>>\n<<if $edengarden lt 4>>"
          },
		   {
            "passage": "Clearing Weeding",
            "findString": "<<physique 6>><<set $edengarden += 1>>",
            "replace": "<<else>>你跪在地上，开始照料庄稼。尽管已经没有杂草，额外的呵护能让长势更好。\n<</if>>\n<<physique 6>><<if $edengarden lt 4>><<set $edengarden += 1>><</if>>"
          },
		   {
            "passage": "Clearing Weeding",
            "findString": "<<if $rng gte 51 and",
            "replace": "<<if $rng gte 51 and $edengarden lt 4 and"
          },
           {
            "passage": "Widgets Avery Mansion",
            "findString": "<<if $avery_mansion.kitchen_made gte 3>>",
            "replace": "<<if $avery_fate isnot \"saved\" and  $avery_fate isnot \"ascended\" >>\n<<set $avery_mansion.kitchen_made to 0>>\n<</if>>\n<<if $avery_mansion.kitchen_made gte 3>>"
          }
        
        ]
      },
       {
         "modName": "ReplacePatcher",
        "addonName": "ReplacePatcherAddon",
        "modVersion": "1.0.0",
        "params": {
         "js": [
         {
           "from": "delete V.alex_to_bed;",
           "to": "delete V.alex_to_bed;\nAutoCleanFarm()",
           "fileName": "time.js"
          },
            {
           "from": "if (V.grace >= 1 && !V.daily.graceUp) statChange.grace(-2);",
           "to": "if(V.housekeeping >= 1000){V.temple_quarters = 100; }\nif(V.tending >= 1000){V.temple_garden = 100;}\nif (V.grace >= 1 && !V.daily.graceUp && V.spear_vessel !=\"temple\") statChange.grace(-2);",
           "fileName": "time.js"
          },
          {
           "from": "if (V.edengarden >= 1) V.edengarden--;",
           "to": "if (V.edengarden != undefined )V.edengarden = 4;",
           "fileName": "time.js"
          },
          {
           "from": "if (V.edenshrooms >= 1) V.edenshrooms--;",
           "to": "if (V.edenshrooms != undefined) V.edenshrooms = 4;",
           "fileName": "time.js"
          },
          {
           "from": "if (V.edenspring >= 1) V.edenspring--;",
           "to": "if (V.edenspring != undefined) V.edenspring = 4;\nif( V.soap != undefined && V.soap < 10 )V.soap = 10;\nif( V.salve != undefined && V.salve < 10 )V.salve = 10;",
           "fileName": "time.js"
          },
          {
           "from": "if (V.bird.clean >= 1)",
           "to": "if(V.bird.upgrades !=undefined && V.bird.upgrades.firepit >= 3 && V.bird.materials.wood < 10 )V.bird.materials.wood = 10;\nif (V.bird.clean >= 1 && V.bird.upgrades !=undefined &&  V.bird.upgrades.shelter < 3)",
           "fileName": "time.js"
          },
          {
           "from": "if (V.bus === \"edencabin\") ",
           "to": "if(1)",
           "fileName": "02-temperature.js"
          },
          {
           "from": "if (V.avery_mansion.bedroom_state",
           "to": "if(V.avery_fate === \"saved\" || V.avery_fate === \"ascended\"){\nV.avery_mansion.pool = 0;\nV.avery_mansion.kitchen = 0;\nV.avery_mansion.lounge = 0;\nV.avery_mansion.display = 0;\nV.avery_mansion.bedroom = 0;\nV.avery_mansion.bathroom = 0;\nV.avery_mansion.garden = 0;\nV.avery_mansion.dining = 0;\nV.avery_mansion.days_absent = 0;\n}\nif (V.avery_mansion.bedroom_state",
           "fileName": "time.js"
          },
           {
           "from": "V.avery_mansion.rage.dinner_missed++;",
           "to": "AutoCleanFeedAvery();",
           "fileName": "time.js"
          }
        ]
      }
    }
    ],
    "dependenceInfo": [
      { 
        "modName": "TweeReplacer",
        "version": "^1.0.0"
      },
	  {
        "modName": "ReplacePatcher",
        "version": "^1.0.0"
       }
    ]
  }